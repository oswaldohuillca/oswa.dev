---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { SITE_URL } from "../consts";

type Props = CollectionEntry<"blog">["data"];

const { title, description, createAt, updatedDate, heroImage } = Astro.props;
const pageTitle = `${title} | Oswaldo Huillca`;
const publishedTime = createAt.toISOString();
const modifiedTime = updatedDate?.toISOString();
const imageUrl = heroImage ? new URL(heroImage, SITE_URL).href : undefined;

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: title,
	description,
	datePublished: publishedTime,
	...(modifiedTime && { dateModified: modifiedTime }),
	...(imageUrl && { image: imageUrl }),
	author: {
		"@type": "Person",
		name: "Oswaldo Huillca Huamani",
	},
	url: new URL(Astro.url.pathname, SITE_URL).href,
};
---

<html lang="es">
	<head>
		<BaseHead
			title={pageTitle}
			description={description}
			image={heroImage}
			imageAlt={title}
			type="article"
			publishedTime={publishedTime}
			modifiedTime={modifiedTime}
		>
			<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
		</BaseHead>
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{
						heroImage && (
							<img width={1020} height={510} src={heroImage} alt={title} />
						)
					}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={createAt} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Última actualización: <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
